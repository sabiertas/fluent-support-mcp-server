{
  "name": "fluent-support-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for Fluent Support - Manage helpdesk tickets and customer support operations",
  "type": "module",
  "main": "dist/fluent-support-mcp-server.js",
  "bin": {
    "fluent-support-mcp": "./dist/fluent-support-mcp-server.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/fluent-support-mcp-server.js",
    "dev": "tsc --watch",
    "start": "FLUENT_SUPPORT_API_USERNAME='$FLUENT_SUPPORT_API_USERNAME' FLUENT_SUPPORT_API_PASSWORD='$FLUENT_SUPPORT_API_PASSWORD' node dist/fluent-support-mcp-server.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "mcp",
    "fluent-support",
    "helpdesk",
    "tickets",
    "customer-support",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.1",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
